# ============================================
# SMRITI BACKEND CONFIGURATION
# ============================================
# Copy to .env and fill in values
# NEVER commit .env to git

# ---------- App ----------
APP_NAME=smriti
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_VERSION=0.1.0
CORS_ORIGINS=http://localhost:3000

# ---------- Security ----------
JWT_SECRET_KEY=                        # openssl rand -hex 32
JWT_REFRESH_SECRET_KEY=                # openssl rand -hex 32 (different from above)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_COST_FACTOR=12
ENCRYPTION_KEY=                        # openssl rand -hex 32 (AES-256 key for PII encryption)

# ---------- PostgreSQL ----------
DATABASE_URL=postgresql+asyncpg://smriti:smriti_dev@localhost:5432/smriti
DATABASE_SSL_MODE=prefer               # require for prod (Supabase)
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---------- Gemini (LLM + Embeddings) ----------
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_API_KEYS=                       # Comma-separated keys for round-robin
GEMINI_MODEL=gemini-3.1-pro-preview
GEMINI_FLASH_MODEL=gemini-3-flash-preview
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview
GEMINI_EMBEDDING_DIMENSION=1536
GEMINI_MAX_TOKENS=8192
GEMINI_TEMPERATURE=0.1
GEMINI_RATE_LIMIT_RPM=60

# ---------- Pinecone (Vector DB) ----------
VECTOR_PROVIDER=pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=smriti-legal
PINECONE_ENVIRONMENT=us-east-1
PINECONE_DIMENSION=1536
PINECONE_METRIC=cosine
PINECONE_CLOUD=aws
PINECONE_TOP_K=20
PINECONE_HOST=                         # Index-specific host URL from Pinecone console

# ---------- Neo4j (Graph DB) ----------
GRAPH_PROVIDER=neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=smriti_dev
NEO4J_DATABASE=neo4j

# ---------- Cohere (Reranker) ----------
RERANKER_PROVIDER=cohere
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-v4.0-pro
COHERE_RERANK_TOP_N=10

# ---------- Indian Kanoon (Legal Doc API) ----------
IK_API_TOKEN=                          # https://api.indiankanoon.org/ — required for case search
IK_RATE_LIMIT=2                        # Max requests/sec (IK limit is 2)

# ---------- Tavily (Web Search) ----------
TAVILY_API_KEY=                        # https://tavily.com — required for web search worker

# ---------- TTS ----------
TTS_PROVIDER=sarvam
SARVAM_API_KEY=

# ---------- Storage ----------
STORAGE_PROVIDER=local                 # local or gcs
LOCAL_STORAGE_PATH=./data/pdfs
GCS_BUCKET_NAME=smriti-documents       # Only needed if STORAGE_PROVIDER=gcs

# ---------- Ingestion ----------
INGESTION_TRACKER_DB=./data/ingestion_tracker.db
INGESTION_BATCH_SIZE=10
INGESTION_CONCURRENCY=5

# ---------- Search ----------
SEARCH_CACHE_TTL=300
SEARCH_FACET_CACHE_TTL=900
SEARCH_RRF_K=60
SEARCH_VECTOR_TOP_K=20
SEARCH_FTS_TOP_K=20
SEARCH_RERANK_TOP_N=10
SEARCH_DEFAULT_PAGE_SIZE=10
SEARCH_MAX_PAGE_SIZE=50

# ---------- Rate Limiting ----------
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_SEARCH=60/minute
RATE_LIMIT_CHAT=10/minute
RATE_LIMIT_INGEST=5/minute

# ---------- Logging ----------
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_PII_REDACTION=true

# ---------- Monitoring ----------
SENTRY_DSN=                            # Optional: Sentry DSN for error tracking
SENTRY_ENVIRONMENT=                    # Optional: defaults to APP_ENV
SENTRY_TRACES_SAMPLE_RATE=0.1          # 10% of transactions sampled

# ---------- DPDP Compliance ----------
DATA_RETENTION_DAYS=365                # Days before inactive data is pruned
