# ============================================
# SMRITI BACKEND CONFIGURATION
# ============================================
# Copy to .env and fill in values
# NEVER commit .env to git

# ---------- App ----------
APP_NAME=smriti
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_VERSION=0.1.0
CORS_ORIGINS=http://localhost:3000

# ---------- Security ----------
JWT_SECRET_KEY=                        # openssl rand -hex 32
JWT_REFRESH_SECRET_KEY=                # openssl rand -hex 32 (different from above)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_COST_FACTOR=12
ENCRYPTION_KEY=                        # openssl rand -hex 32 (AES-256 key for PII encryption)

# ---------- PostgreSQL ----------
DATABASE_URL=postgresql+asyncpg://smriti:smriti_dev@localhost:5432/smriti
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---------- Gemini (LLM + Embeddings) ----------
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSION=1536

# ---------- Pinecone (Vector DB) ----------
VECTOR_PROVIDER=pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=smriti-legal
PINECONE_HOST=                             # Index-specific host URL from Pinecone console (e.g. https://smriti-legal-abc123.svc.us-east-1.pinecone.io)

# ---------- Neo4j (Graph DB) ----------
GRAPH_PROVIDER=neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=smriti_dev
NEO4J_DATABASE=neo4j

# ---------- Cohere (Reranker) ----------
RERANKER_PROVIDER=cohere
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-v4.0-pro
COHERE_RERANK_TOP_N=10

# ---------- TTS ----------
TTS_PROVIDER=sarvam
SARVAM_API_KEY=

# ---------- Storage ----------
STORAGE_PROVIDER=local                 # local or gcs
LOCAL_STORAGE_PATH=./data/pdfs
GCS_BUCKET_NAME=smriti-documents       # Only needed if STORAGE_PROVIDER=gcs

# ---------- Ingestion ----------
INGESTION_TRACKER_DB=./data/ingestion_tracker.db

# ---------- Monitoring ----------
LOG_LEVEL=INFO
SENTRY_DSN=                            # Optional: Sentry DSN for error tracking
SENTRY_ENVIRONMENT=                    # Optional: defaults to APP_ENV
SENTRY_TRACES_SAMPLE_RATE=0.1          # 10% of transactions sampled

# ---------- DPDP Compliance ----------
DATA_RETENTION_DAYS=365                # Days before inactive data is pruned
