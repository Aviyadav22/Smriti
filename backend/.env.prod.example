# === Production Environment Template ===
# Copy to .env.prod and fill in values
# DO NOT commit .env.prod to git

# --- Provider Selection ---
VECTOR_PROVIDER=pgvector
GRAPH_PROVIDER=postgresql

# --- Database (set via docker-compose, but needed for alembic) ---
# DATABASE_URL is set in docker-compose.prod.yml via env vars
# REDIS_URL is set in docker-compose.prod.yml via env vars

# --- LLM & AI ---
GEMINI_API_KEY=your_gemini_api_key
COHERE_API_KEY=your_cohere_api_key

# --- Auth ---
JWT_SECRET_KEY=generate_with_openssl_rand_hex_32
ENCRYPTION_KEY=generate_with_openssl_rand_hex_32

# --- Optional: Cloud providers (only if VECTOR_PROVIDER=pinecone / GRAPH_PROVIDER=neo4j) ---
# PINECONE_API_KEY=
# PINECONE_HOST=
# NEO4J_URI=
# NEO4J_USER=
# NEO4J_PASSWORD=
# NEO4J_DATABASE=

# --- Storage ---
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/app/uploads
